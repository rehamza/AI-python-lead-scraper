DATABASE_URL=postgresql+psycopg://USER@localhost:5432/leadgen

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Free-first: DDG (no key) and self-hosted SearXNG absorb the load; paid
# Serper and rate-limited Brave only kick in when the free providers fail.
SEARCH_PROVIDER_ORDER=ddg,searxng,serper,brave
SERPER_API_KEY=
BRAVE_API_KEY=
SEARXNG_URL=

# Off by default — probing at volume under your own domain risks IP/domain
# reputation. See the comment in .env for details before enabling.
SMTP_VERIFY_ENABLED=false
SMTP_HELO_DOMAIN=yourdomain.com
SMTP_FROM_ADDRESS=verify@yourdomain.com

AGENT_MAX_CONCURRENT_SEARCHES=4
AGENT_MAX_CONCURRENT_CRAWLS=8
AGENT_QUALIFY_BATCH_SIZE=10
